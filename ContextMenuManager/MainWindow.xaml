<Window x:Class="ContextMenuManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        mc:Ignorable="d"
        Title="ContextMenuManager"
        Height="610" Width="850"
        MinHeight="450" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Navigation View (replaces WinForms MyToolBar + MySideBar) -->
        <ui:NavigationView x:Name="NavView"
                           Grid.Row="0"
                           IsSettingsVisible="False"
                           IsBackButtonVisible="Collapsed"
                           OpenPaneLength="185"
                           SelectionChanged="NavView_SelectionChanged">
            <!-- Refresh button pinned to pane footer -->
            <ui:NavigationView.PaneFooter>
                <Button x:Name="RefreshButton"
                        Margin="4,4,4,8"
                        HorizontalAlignment="Stretch"
                        Click="RefreshButton_Click" />
            </ui:NavigationView.PaneFooter>

            <!-- Main content area -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Search box -->
                <TextBox x:Name="SearchBox"
                         Grid.Row="0"
                         Margin="8,4"
                         ui:ControlHelper.PlaceholderText="Search..."
                         TextChanged="SearchBox_TextChanged" />

                <!-- WinForms content controls hosted via WindowsFormsHost -->
                <WindowsFormsHost x:Name="ContentHost" Grid.Row="1" />
            </Grid>
        </ui:NavigationView>

        <!-- Status Bar -->
        <StatusBar Grid.Row="1">
            <StatusBarItem HorizontalContentAlignment="Stretch">
                <TextBlock x:Name="StatusText" Padding="4,2" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
