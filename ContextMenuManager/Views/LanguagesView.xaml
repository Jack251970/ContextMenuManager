<UserControl
    x:Class="ContextMenuManager.Views.LanguagesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PageForegroundBrush" Color="#F3F3F3" />
        <SolidColorBrush x:Key="PageMutedBrush" Color="#B8B8B8" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1B1B1B" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#303030" />
        <SolidColorBrush x:Key="AccentBrush" Color="#F29D38" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock
                    x:Name="PageTitleText"
                    Foreground="{StaticResource PageForegroundBrush}"
                    FontSize="22"
                    FontWeight="SemiBold" />
                <TextBlock
                    x:Name="PageDescriptionText"
                    Margin="0,8,0,0"
                    Foreground="{StaticResource PageMutedBrush}"
                    FontSize="13"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,20,0">
                        <TextBlock
                            x:Name="LanguageLabel"
                            Foreground="{StaticResource PageForegroundBrush}"
                            FontSize="15"
                            FontWeight="SemiBold" />
                        <TextBlock
                            x:Name="LanguageHintText"
                            Margin="0,4,0,0"
                            Foreground="{StaticResource PageMutedBrush}"
                            FontSize="12"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ComboBox
                            x:Name="LanguageComboBox"
                            MinWidth="240"
                            VerticalAlignment="Center"
                            SelectionChanged="LanguageComboBox_OnSelectionChanged" />
                        <Button
                            x:Name="OpenLanguageDirButton"
                            Margin="12,0,0,0"
                            Padding="14,7"
                            Click="OpenLanguageDirButton_OnClick" />
                        <Button
                            x:Name="DownloadLanguageButton"
                            Margin="12,0,0,0"
                            Padding="14,7"
                            Click="DownloadLanguageButton_OnClick" />
                        <Button
                            x:Name="TranslateButton"
                            Margin="12,0,0,0"
                            Padding="14,7"
                            Click="TranslateButton_OnClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Margin="0,20,0,0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        x:Name="TranslatorsHeaderText"
                        Foreground="{StaticResource AccentBrush}"
                        FontSize="18"
                        FontWeight="SemiBold" />

                    <TextBlock
                        x:Name="ThankYouText"
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        Foreground="{StaticResource PageMutedBrush}"
                        FontFamily="Lucida Handwriting"
                        FontSize="16" />

                    <ListView
                        x:Name="TranslatorsListView"
                        Grid.Row="2"
                        Margin="0,18,0,0"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding TranslatorGroups, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12" Padding="0,0,0,12" BorderBrush="#303030" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock
                                            Text="{Binding LanguageDisplayName}"
                                            Foreground="{StaticResource PageForegroundBrush}"
                                            FontSize="15"
                                            FontWeight="SemiBold" />
                                        <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Translators}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock
                                                        Margin="0,0,0,6"
                                                        Cursor="{Binding Cursor}"
                                                        Foreground="{Binding Foreground}"
                                                        MouseLeftButtonUp="TranslatorLink_OnMouseLeftButtonUp"
                                                        Tag="{Binding Url}"
                                                        Text="{Binding Name}"
                                                        TextDecorations="{Binding Decorations}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
