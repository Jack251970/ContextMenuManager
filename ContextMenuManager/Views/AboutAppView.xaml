<UserControl
    x:Class="ContextMenuManager.Views.AboutAppView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1F1F1F" />
            <Setter Property="BorderBrush" Value="#343434" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="24" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock
                        x:Name="AppNameText"
                        FontSize="28"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="DescriptionText"
                        Margin="0,10,0,0"
                        Foreground="#C9C9C9"
                        TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock
                            x:Name="ProjectLinksHeader"
                            FontSize="18"
                            FontWeight="SemiBold" />
                        <TextBlock
                            x:Name="GitHubLinkText"
                            Margin="0,16,0,0"
                            Cursor="Hand"
                            Foreground="#F5A623"
                            MouseLeftButtonUp="GitHubLinkText_OnMouseLeftButtonUp"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="GiteeLinkText"
                            Margin="0,10,0,0"
                            Cursor="Hand"
                            Foreground="#F5A623"
                            MouseLeftButtonUp="GiteeLinkText_OnMouseLeftButtonUp"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="LicenseText"
                            Margin="0,16,0,0"
                            Foreground="#D9D9D9"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2" Margin="0,20,0,0" Orientation="Horizontal">
                    <Button
                        x:Name="CheckUpdateButton"
                        MinWidth="180"
                        Padding="16,8"
                        Click="CheckUpdateButton_OnClick" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
